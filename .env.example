# Remora configuration — copy to .env and fill in.
# All values shown here are defaults applied when the variable is unset
# or empty (see internal/config/config.go).

# ───────────────────────────── GitHub App ─────────────────────────────
# Required. Get these after creating your GitHub App.
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# ─────────────────────────────── Database ─────────────────────────────
# One of: postgresql, mysql, sqlite
DATABASE_TYPE=sqlite

# Required when DATABASE_TYPE is postgresql or mysql.
DATABASE_HOST=
DATABASE_PORT=          # Defaults: 5432 (postgresql), 3306 (mysql)
DATABASE_NAME=
DATABASE_USER=
DATABASE_PASSWORD=

# PostgreSQL only: disable | require | verify-ca | verify-full
DATABASE_SSLMODE=disable

# SQLite only: file path for the database.
DATABASE_SQLITE_PATH=./data/remora.db

# Connection pool.
DATABASE_MAX_OPEN_CONNS=25
DATABASE_MAX_IDLE_CONNS=5
DATABASE_CONN_MAX_LIFETIME=300   # seconds

# ───────────────────────────── HTTP server ────────────────────────────
REMORA_PORT=8080
REMORA_WEBHOOK_PATH=/webhook
REMORA_HEALTH_PATH=/health
REMORA_READY_PATH=/ready

# ────────────────────────────── Scheduler ─────────────────────────────
# Minutes between polling cycles for due reminders.
REMORA_SCHEDULER_INTERVAL=5

# ─────────────────────────── Reminder behavior ────────────────────────
# reaction_only         — react with ❌ on parse errors, post nothing.
# reaction_and_comment  — also post an explanatory comment.
REMORA_ERROR_MODE=reaction_only

# When false, reminders due on closed issues/PRs are dropped instead
# of posted.
REMORA_POST_TO_CLOSED=true

# ─────────────────────────────── Admin API ────────────────────────────
# Optional read-only query API. When enabled, REMORA_API_SECRET must
# be set; clients pass it in the X-API-Key header.
REMORA_ENABLE_API=false
REMORA_API_SECRET=

# ─────────────────────────── Rate limiting ────────────────────────────
# Requests per minute per client (admin API and webhook).
REMORA_RATE_LIMIT=60

# ─────────────────────────────── Logging ──────────────────────────────
# debug | info | warn | error | fatal
LOG_LEVEL=info
