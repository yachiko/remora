# Database Configuration
# Supported: postgresql, mysql, sqlite
DATABASE_TYPE=postgresql

# PostgreSQL/MySQL Configuration
DATABASE_HOST=localhost
DATABASE_PORT=5432  # 5432 for PostgreSQL, 3306 for MySQL
DATABASE_NAME=remora
DATABASE_USER=remora_user
DATABASE_PASSWORD=your_secure_password
DATABASE_SSLMODE=disable  # For PostgreSQL: disable, require, verify-ca, verify-full

# SQLite Configuration (alternative to above)
# DATABASE_TYPE=sqlite
# DATABASE_NAME=./remora.db

# HTTP Server Configuration
REMORA_PORT=8080
REMORA_WEBHOOK_PATH=/webhook
REMORA_HEALTH_PATH=/health
REMORA_READY_PATH=/ready

# GitHub App Configuration
GITHUB_APP_ID=123456
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GITHUB_WEBHOOK_SECRET=your-webhook-secret-here

# Scheduler Configuration
REMORA_SCHEDULER_INTERVAL=5  # Minutes between scheduler runs

# Error Handling
# Options: reaction_only, reaction_and_comment
REMORA_ERROR_MODE=reaction_only

# Reminder Behavior
REMORA_POST_TO_CLOSED=true  # Post reminders to closed issues/PRs

# Admin API (Optional)
REMORA_ENABLE_API=false
REMORA_API_SECRET=your-admin-secret-here

# Rate Limiting
REMORA_RATE_LIMIT=60  # Max webhook requests per minute

# Logging
ENVIRONMENT=development  # development or production
LOG_LEVEL=info  # debug, info, warn, error, fatal
